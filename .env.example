# Outreach Studio environment variables
# Copy to .env and fill in.

# --- Server-side only (read by server/index.ts, the Notion proxy) ---------
# NEVER prefix these with VITE_ — that would inline them into the client
# bundle, where anyone could read them via devtools. The whole reason a
# proxy server exists is to keep these off the browser entirely.
#
# Create an integration at https://www.notion.so/my-integrations, then
# share your Leads database with it ("..." menu → Connections).
NOTION_API_KEY=
# The database id from its URL: notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_DATABASE_ID=
# Port the proxy listens on. Vite's dev-server proxy (vite.config.ts)
# forwards /api/* here.
PORT=8787

# --- Client-exposed (must be prefixed VITE_ to reach the browser) ---------
# None currently — the SPA only ever calls same-origin /api/* routes.
